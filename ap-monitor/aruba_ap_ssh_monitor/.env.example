# --- Aruba Controller SSH ---
CONTROLLERS=192.168.100.100            # comma-separated if multiple
SSH_USERNAME=admin
SSH_PASSWORD=changeme
# Optional private key instead of password
# SSH_KEY_PATH=C:\\path\\to\\id_rsa

# --- Email (SMTP) ---
SMTP_HOST=smtp.office365.com           # or smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Aruba Monitor <you@example.com>
SMTP_TO=netops@example.com, noc@example.com

# --- Behavior ---
ALERT_THRESHOLD=5                      # alert if >= this many APs down in the last 24h
DATA_DIR=./data                        # where CSV/history are stored
