# --- Aruba Controller SSH ---
CONTROLLERS=192.168.100.100            # comma-separated if multiple
SSH_USERNAME=admin
SSH_PASSWORD=changeme
SSH_PORT=22
DEVICE_TYPE=aruba_os
FALLBACK_TO_22=false

# --- Behavior ---
DATA_DIR=./data
POLL_INTERVAL_MINUTES=10
ALERT_THRESHOLD=5                      # alert if >= this many APs down
ALERT_COOLDOWN_MINUTES=60
DAILY_HOUR=17
DAILY_MINUTE=0

# --- Email (SMTP) ---
SMTP_HOST=smtp.office365.com           # or smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Aruba Monitor <you@example.com>
SMTP_TO=netops@example.com, noc@example.com
